local dragStart, dragFrame, isDrag = nil, nil, false

drag.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDrag = true
        dragStart = input.Position
        dragFrame = win.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isDrag and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        win.Position = UDim2.new(dragFrame.X.Scale, dragFrame.X.Offset + delta.X, dragFrame.Y.Scale, dragFrame.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDrag = false
    end
end)

